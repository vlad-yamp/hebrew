<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/grey_light"
    android:clipChildren="false">

    <TextView
        android:id="@+id/tvAppTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🇮🇱"
        android:textSize="48sp"
        android:layout_marginTop="48dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvCardCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minHeight="24dp"
        android:textSize="14sp"
        android:textColor="@color/colorPrimary"
        android:textStyle="bold"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvAppTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/hint_voice"
        android:textSize="16sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:padding="16dp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvCardCount"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/langToggle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:singleSelection="true"
        app:selectionRequired="true"
        app:layout_constraintTop_toBottomOf="@id/tvHint"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLangHebrew"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/lang_hebrew"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLangRussian"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/lang_russian"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

    </com.google.android.material.button.MaterialButtonToggleGroup>

    <!-- Input area: mic OR text input, switches based on mode -->
    <FrameLayout
        android:id="@+id/inputContainer"
        android:layout_width="0dp"
        android:layout_height="148dp"
        android:layout_marginTop="32dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/langToggle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Mic button (default, mic mode) -->
        <ImageButton
            android:id="@+id/btnMic"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_gravity="center_horizontal|top"
            android:background="@drawable/bg_mic_button"
            android:src="@android:drawable/ic_btn_speak_now"
            android:scaleType="centerInside"
            android:padding="24dp"
            android:contentDescription="Микрофон" />

        <!-- Ripple pulse circles on top of button (clipped by button shape visually) -->
        <View
            android:id="@+id/ripple1"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_gravity="center_horizontal|top"
            android:background="@drawable/ic_ripple_circle"
            android:alpha="0"
            android:visibility="invisible" />

        <View
            android:id="@+id/ripple2"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_gravity="center_horizontal|top"
            android:background="@drawable/ic_ripple_circle"
            android:alpha="0"
            android:visibility="invisible" />

        <View
            android:id="@+id/ripple3"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_gravity="center_horizontal|top"
            android:background="@drawable/ic_ripple_circle"
            android:alpha="0"
            android:visibility="invisible" />

        <!-- Text input (hidden by default, text mode) -->
        <LinearLayout
            android:id="@+id/layoutTextInput"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="8dp"
            android:visibility="gone">

            <EditText
                android:id="@+id/etManualInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="22sp"
                android:textColor="@color/colorPrimary"
                android:inputType="textMultiLine"
                android:minLines="1"
                android:maxLines="4"
                android:background="@null"
                android:hint="Введите текст..."
                android:imeOptions="flagNoEnterAction" />

            <ImageButton
                android:id="@+id/btnSendText"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_arrow_forward"
                android:tint="@color/colorPrimary"
                android:contentDescription="Перевести" />

        </LinearLayout>

    </FrameLayout>

    <!-- Input mode selectors -->
    <LinearLayout
        android:id="@+id/layoutInputModes"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/inputContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnInputMic"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_mic"
            android:tint="@color/colorPrimary"
            android:contentDescription="Голосовой ввод" />

        <ImageButton
            android:id="@+id/btnInputClipboard"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_paste"
            android:tint="@color/grey_medium"
            android:contentDescription="Вставить из буфера" />

        <ImageButton
            android:id="@+id/btnInputKeyboard"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_pencil"
            android:tint="@color/grey_medium"
            android:contentDescription="Ввод текста" />

    </LinearLayout>

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:layout_marginTop="16dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/layoutInputModes"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/tvStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
