<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/grey_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Input card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvInputLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Иврит"
                        android:textSize="12sp"
                        android:textColor="@color/grey_medium"
                        android:textAllCaps="true" />

                    <ImageButton
                        android:id="@+id/btnTransliterateHebrew"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_transliterate"
                        android:tint="@color/colorPrimary"
                        android:contentDescription="Транслитерация"
                        android:visibility="gone" />

                    <ImageButton
                        android:id="@+id/btnConjugate"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_conjugate"
                        android:tint="@color/colorPrimary"
                        android:contentDescription="@string/analysis_conjugation_title"
                        android:visibility="gone" />

                    <ImageButton
                        android:id="@+id/btnSyntax"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_syntax"
                        android:tint="@color/colorPrimary"
                        android:contentDescription="@string/analysis_syntax_title"
                        android:visibility="gone" />

                    <ImageButton
                        android:id="@+id/btnSpeakHebrew"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_speak"
                        android:tint="@color/colorPrimary"
                        android:contentDescription="Озвучить"
                        android:visibility="gone" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvTransliterationInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="@color/grey_medium"
                    android:fontFamily="monospace"
                    android:layout_marginTop="4dp"
                    android:visibility="gone" />

                <EditText
                    android:id="@+id/etInputText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorPrimary"
                    android:background="@null"
                    android:inputType="textMultiLine"
                    android:minLines="1"
                    android:maxLines="5"
                    android:layout_marginTop="4dp" />

                <ImageButton
                    android:id="@+id/btnRetranslate"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="end"
                    android:layout_marginTop="4dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_arrow_forward"
                    android:tint="@color/colorPrimary"
                    android:contentDescription="@string/btn_retranslate" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Translation loading -->
        <ProgressBar
            android:id="@+id/progressTranslation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp"
            android:visibility="gone" />

        <!-- Single translation -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardSingleTranslation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvTranslationLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Перевод"
                    android:textSize="12sp"
                    android:textColor="@color/grey_medium"
                    android:textAllCaps="true" />

                <TextView
                    android:id="@+id/tvSingleTranslation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="22sp"
                    android:textColor="@color/text_primary"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Multiple translation variants -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardVariants"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvVariantsLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/select_translation"
                    android:textSize="14sp"
                    android:textColor="@color/grey_medium"
                    android:layout_marginBottom="8dp" />

                <RadioGroup
                    android:id="@+id/radioGroupVariants"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Hebrew result actions (visible only for Russian→Hebrew) -->
        <LinearLayout
            android:id="@+id/hebrewActionsBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="12dp"
            android:visibility="gone">

            <ImageButton
                android:id="@+id/btnSpeakResult"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_speak"
                android:tint="@color/colorPrimary"
                android:contentDescription="Произнести" />

            <ImageButton
                android:id="@+id/btnTransliterateResult"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_transliterate"
                android:tint="@color/colorPrimary"
                android:contentDescription="Транслитерация" />

            <ImageButton
                android:id="@+id/btnConjugateResult"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_conjugate"
                android:tint="@color/colorPrimary"
                android:contentDescription="@string/analysis_conjugation_title" />

            <ImageButton
                android:id="@+id/btnSyntaxResult"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_syntax"
                android:tint="@color/colorPrimary"
                android:contentDescription="@string/analysis_syntax_title" />

            <ImageButton
                android:id="@+id/btnCopyHebrew"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="16dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_copy"
                android:tint="@color/colorPrimary"
                android:contentDescription="Копировать" />

            <ImageButton
                android:id="@+id/btnShareHebrew"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="16dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_share"
                android:tint="@color/colorPrimary"
                android:contentDescription="Поделиться" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvTransliterationResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="@color/grey_medium"
            android:fontFamily="monospace"
            android:gravity="center"
            android:layout_marginBottom="8dp"
            android:visibility="gone" />

        <!-- Analysis loading -->
        <ProgressBar
            android:id="@+id/progressAnalysis"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="8dp"
            android:visibility="gone" />

        <!-- Examples button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnExamples"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="12dp"
            android:text="@string/btn_examples"
            android:visibility="gone"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        <!-- Examples loading -->
        <ProgressBar
            android:id="@+id/progressExamples"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="8dp"
            android:visibility="gone" />

        <!-- Examples list (populated dynamically) -->
        <LinearLayout
            android:id="@+id/examplesContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="8dp" />

        <!-- Save card button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="@string/btn_save_card"
            android:visibility="gone" />

        <!-- New input button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNewInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_new_input"
            android:visibility="gone"
            style="@style/Widget.MaterialComponents.Button.TextButton" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
